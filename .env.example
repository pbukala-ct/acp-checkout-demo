# commercetools project credentials
CTP_PROJECT_KEY=your-project-key
CTP_CLIENT_SECRET=your-client-secret
CTP_CLIENT_ID=your-client-id
CTP_AUTH_URL=https://auth.<region>.gcp.commercetools.com
CTP_API_URL=https://api.<region>.gcp.commercetools.com
CTP_SCOPES=manage_project:your-project-key

# ACP connector service base URL (no trailing slash)
ACP_SERVICE_HOST=https://your-acp-service-host.example.com

# Stripe test secret key (sk_test_... format)
STRIPE_TEST_KEY=sk_test_your_stripe_test_key_here
